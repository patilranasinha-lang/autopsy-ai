# ===========================================
# Autopsy AI - Environment Variables (Example)
# ===========================================
# Copy this file to .env and modify values
# DO NOT commit .env to git!
# ===========================================

# ===================
# General Ports
# ===================
FRONTEND_PORT=3000
BACKEND_PORT=5000
DB_PORT=5432

# ===================
# PostgreSQL Database
# ===================
POSTGRES_USER=autopsy_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=autopsy_ai
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ===================
# Backend Security
# ===================
SECRET_KEY=your_very_secure_secret_key_change_this_in_production
JWT_SECRET_KEY=your_secure_jwt_secret_change_this_in_production

# ===================
# Logging
# ===================
LOG_LEVEL=DEBUG  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL